{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "airdropreworked",
  "version": "0.1.0",
  "identifier": "com.adrw.reworked",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run build:engine && npm run dev",
    "beforeBuildCommand": "npm run build:engine && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "airdropreworked",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; connect-src 'self' http://localhost:* http://127.0.0.1:*; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/adrw-engine"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}